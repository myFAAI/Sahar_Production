PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/sa_ai
# Railway database services may also expose one of these names:
# MONGODB_URL, MONGO_URL, DATABASE_URL
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Development
CORS_ORIGIN=http://localhost:5173

# Production (uncomment for production)
# NODE_ENV=production
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sa_ai?retryWrites=true&w=majority
# JWT_SECRET=your_secure_random_secret_key_here
# CORS_ORIGIN=https://your-domain.com
